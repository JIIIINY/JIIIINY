{
  "$schema": "morphing-motion/v2",
  "meta": {
    "name": "Organic Gradient Morphing Motion",
    "description": "9개 그라디언트 형태를 유기적으로 몰핑하는 AI agent 모션. 고해상도 레퍼런스 재분석 기반 — 색은 1D 스톱이 아니라 형태 내부에 위치를 가진 색점들의 메시(mesh) 그라디언트로 정의한다. 형태별로 엣지 선명도/블러 영역/그레인이 다르다.",
    "source": "IMG_9912 (9-grid) + IMG_9915/9916/9917/9920 (closeups)",
    "author": "@danielsmile (reference) / generated config",
    "created": "2026-06-20",
    "units": { "space": "normalized 0..1 (shape-local)", "time": "ms", "angle": "deg" }
  },

  "canvas": {
    "viewBox": [0, 0, 1000, 1000],
    "aspectRatio": "1:1",
    "background": { "type": "solid", "color": "#0B0E16",
      "vignette": { "enabled": true, "color": "#05070B", "strength": 0.45, "radius": 0.85 } },
    "renderHints": {
      "colorSpace": "display-p3", "blendMode": "screen",
      "filmGrain": { "enabled": true, "opacity": 0.10, "scale": 1.4 }
    },
    "colorModel": {
      "type": "mesh-rbf",
      "comment": "픽셀 색 = Σ wᵢ·cᵢ / Σ wᵢ,  wᵢ = weightᵢ·exp(-k·(d/radiusᵢ)²). 색점을 형태 안 2D 위치에 배치해 화이트 코어+다방향 색(예: SHAPES 37)을 재현. SVG/Canvas는 색점을 color→transparent 소프트 라디얼로 edge→core 순서로 스택하여 근사.",
      "k": 2.6, "pointOrder": "edge-first → core-last (밝은 코어가 위에 쌓이도록)"
    },
    "renderModel": {
      "comment": "세 영역 분리: (1)glow 헤일로(블러 영역, 형태와 독립) (2)form(선명 실루엣+메시 색, 얇은 페더) (3)grain 표면 노이즈.",
      "params": "edgeFeather(실루엣 부드러움 0..1), glow{spread,opacity}, grain(0..1)"
    }
  },

  "globalMotion": {
    "loop": true, "playbackRate": 1.0, "morphDurationMs": 2600, "holdDurationMs": 1400,
    "easing": "cubic-bezier(0.65, 0.0, 0.35, 1.0)",
    "organicNoise": { "enabled": true, "type": "simplex", "amplitude": 0.05, "speed": 0.12, "seed": 9912,
      "comment": "정점을 미세하게 흔들어 액체/연기 같은 흐름" },
    "breathing": { "enabled": true, "scaleRange": [0.96, 1.05], "rotationRange": [-6, 6], "periodMs": 5200 }
  },

